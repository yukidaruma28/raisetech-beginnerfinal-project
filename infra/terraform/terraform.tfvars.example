# このファイルをコピーして terraform.tfvars を作成し、実値を入力する
# terraform.tfvars は .gitignore に含まれているのでコミットされない

aws_region  = "ap-northeast-1"
aws_profile = "kanban"
project     = "kanban-linear"

# EC2 への HTTP(8080) アクセスを許可する CIDR
# ポートフォリオとして公開する場合は ["0.0.0.0/0"]
# 特定 IP のみ許可する場合は ["xxx.xxx.xxx.xxx/32"]
allowed_ingress_cidrs = ["0.0.0.0/0"]

# RDS MySQL
db_instance_class = "db.t3.micro"
db_name           = "inquiry_tracker_production"
db_username       = "inquiry"
db_password       = "強いパスワードをここに入力"  # 例: openssl rand -base64 32
