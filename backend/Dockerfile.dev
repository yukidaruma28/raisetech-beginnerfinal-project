# 開発用 Rails コンテナ
# 本番用 Dockerfile（同階層）とは別に、ホット再読み込み・bundle キャッシュ前提で構成
FROM ruby:3.4-slim

ENV LANG=C.UTF-8 \
    BUNDLE_PATH=/usr/local/bundle

RUN apt-get update -qq && \
    apt-get install -y --no-install-recommends \
      build-essential \
      default-libmysqlclient-dev \
      pkg-config \
      git \
      curl \
      libyaml-dev \
      libffi-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /rails

EXPOSE 3001

CMD ["bash", "-c", "bundle install && bundle exec rails db:prepare && bundle exec rails server -p 3001 -b 0.0.0.0"]
